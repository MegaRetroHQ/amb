# Postgres с хоста (порт зависит от режима):
# - разработка: `pnpm deploy:dev:db` → docker-compose.dev.yml → localhost:5434 (отдельный том от полного стека)
# - полный стек / потребитель: `pnpm deploy:local` → docker-compose.yml → localhost:5433
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/amb
JWT_SECRET=change-me-for-local-dev

# Production: NODE_ENV=production (set in Docker image). Swagger UI is disabled unless:
# AMB_SWAGGER_ENABLED=true

# Optional: first-time server bootstrap — upsert default tenant only (no default user).
# AMB_BOOTSTRAP=true

# Rate limit: запросов на бакет (tenant+project+ip+method) за окно. 0 = отключить. По умолчанию 20000/мин.
# RATE_LIMIT_MAX_REQUESTS=20000
# RATE_LIMIT_WINDOW_MS=60000
