datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "./generated"
}
model Agent {
  id           String   @id @default(uuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name         String
  role         String
  status       String   @default("online")
  capabilities Json?

  createdAt DateTime @default(now())
  lastSeen  DateTime?

  @@index([projectId])
}

model Thread {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  status    String   @default("open")
  createdAt DateTime @default(now())

  messages Message[]

  @@index([projectId])
}

model Message {
  id String @id @default(uuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  threadId String
  thread   Thread @relation(fields: [threadId], references: [id])

  fromAgentId String
  toAgentId   String?

  payload Json

  status  String @default("pending")
  retries Int    @default(0)

  parentId String?
  parent   Message? @relation("Replies", fields: [parentId], references: [id])
  replies  Message[] @relation("Replies")

  createdAt DateTime @default(now())

  @@index([threadId])
  @@index([projectId])
  @@index([toAgentId])
  @@index([fromAgentId])
  @@index([status])
  @@index([createdAt])
}

model Project {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  agents   Agent[]
  threads  Thread[]
  messages Message[]
}
